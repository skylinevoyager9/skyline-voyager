# =============================================================================
# Duffel Flights API (server-only — never use NEXT_PUBLIC_ for the token)
# =============================================================================
#
# Test: duffel_test_ + DUFFEL_MODE=test
# Live: duffel_live_ + DUFFEL_MODE=live (fund Duffel balance or pay-as-you-go for ticketing)
# Stays: request Stays API access in Duffel dashboard (Developers → Stays)
#
# DUFFEL_API_TOKEN=duffel_test_xxxxxxxx
# DUFFEL_MODE=test
# DUFFEL_VERSION=v2
# FLIGHT_MARKUP_PERCENT=8
# FLIGHT_MARKUP_MIN_PERCENT=0
# FLIGHT_MARKUP_MAX_PERCENT=20
# FLIGHT_SEARCH_TIMEOUT_MS=20000
#
# Owner margin view + publish live service fee (server-only)
# /flights/search?owner=YOUR_SECRET → Publish to live site
# OWNER_PRICING_KEY=change-me-to-a-long-random-string
#
# NEXT_PUBLIC_FLIGHT_PRICE_DISCLOSURE=simple
#
# Stays uses the same Duffel + Stripe + markup vars above (no extra keys).
# Request Stays API access from Duffel support if /stays/search returns 403.
#
# =============================================================================
# Stripe (card checkout before Duffel booking)
# =============================================================================
#
# Test: sk_test_ + pk_test_  |  Live: sk_live_ + pk_live_
# STRIPE_SECRET_KEY=sk_test_...
# NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY=pk_test_...
#
# Stripe Dashboard → Developers → Webhooks → endpoint:
#   https://your-domain.com/api/stripe/webhook
# Events: payment_intent.succeeded, payment_intent.payment_failed
# STRIPE_WEBHOOK_SECRET=whsec_...
#
# =============================================================================
# Duffel webhooks (schedule changes, order updates)
# =============================================================================
#
# Webhook URL (Duffel dashboard only — NOT DUFFEL_WEBHOOK_SECRET):
#   https://your-domain.com/api/duffel/webhook
#
# Option A — manual: copy secret once at create into Vercel:
# DUFFEL_WEBHOOK_SECRET=paste-secret-from-duffel-here
#
# Option B — auto-sync (recommended on Vercel; requires Upstash below):
# 1) Set a random setup key (remove after sync if you like):
# DUFFEL_WEBHOOK_SETUP_KEY=generate-a-long-random-string
# 2) Deploy, then:
#    curl -X POST "https://your-domain.com/api/admin/duffel-webhook/sync" \
#      -H "Authorization: Bearer YOUR_SETUP_KEY"
#    This recreates the Duffel webhook and stores the secret in Upstash (no paste mistakes).
#
# =============================================================================
# Upstash Redis (recommended on Vercel — published fee + booking records)
# =============================================================================
#
# https://upstash.com → Redis → REST API
# UPSTASH_REDIS_REST_URL=https://xxxx.upstash.io
# UPSTASH_REDIS_REST_TOKEN=...
#
# Without Upstash: published fee uses data/published-flight-markup.json (local);
# bookings append to data/bookings.jsonl (local).
#
# =============================================================================
# Contact form (Resend)
# =============================================================================
#
# RESEND_API_KEY=re_xxxxxxxx
# CONTACT_TO_EMAIL=you@example.com
# CONTACT_FROM_EMAIL=Skyline Voyager <bookings@skylinevoyager.com>
#
# Owner: BCC on every flight/stay confirmation (falls back to CONTACT_TO_EMAIL, then site email)
# BOOKING_OWNER_EMAIL=you@example.com
# CONTACT_FROM_EMAIL=Skyline Voyager <hello@yourdomain.com>
#
# =============================================================================
# Optional outbound partners (cars, tours) — NOT used for flight booking
# =============================================================================
#
# NEXT_PUBLIC_CAR_RENTAL_AFFILIATE_URL=https://...
# NEXT_PUBLIC_VIATOR_AFFILIATE_URL=https://www.viator.com/...
# NEXT_PUBLIC_GETYOURGUIDE_AFFILIATE_URL=https://www.getyourguide.com/...
